# Copy to ".env.local" next to package.json, then restart `npm run dev`.
# Vercel: set the same names under Project → Settings → Environment Variables.

# Required for the map (https://www.maptiler.com/)
NEXT_PUBLIC_MAPTILER_KEY=

# Optional: foot routing via OpenRouteService (otherwise public OSRM demo)
# OPENROUTESERVICE_API_KEY=

# Optional: bump to bust stale browser chunks after deploys
# NEXT_PUBLIC_KEPI_BUILD=1

# Optional: transport update mode for travel assistant page.
# - auto: use configured server providers, fallback to mock when no keys
# - mock: force deterministic mock provider
# - off: disable provider checks
# NEXT_PUBLIC_TRAVEL_UPDATES_MODE=auto

# Optional server-side flight provider integration (kept private; do not use NEXT_PUBLIC_*)
# FLIGHT_STATUS_API_URL=
# FLIGHT_STATUS_API_KEY=

# Optional server-side rail provider integration (kept private; do not use NEXT_PUBLIC_*)
# RAIL_STATUS_API_URL=
# RAIL_STATUS_API_KEY=

# Vercel KV credentials (Project -> Storage -> KV -> .env.local snippet)
# Required for production/serverless persistence across regions.
# KV_REST_API_URL=
# KV_REST_API_TOKEN=

# Optional logical key overrides for KV-backed travel assistant stores.
# If omitted, defaults are used under the "kepi:" namespace.
# TRAVEL_UPDATE_AUDIT_PATH=travel/update-audit/default

# Optional logical key override for latest runtime reservation snapshot.
# TRAVEL_UPDATE_RUNTIME_STATE_PATH=travel/runtime-state/default

# Optional secret for /api/travel-updates/background route
# - Send via header `x-travel-cron-secret` or Bearer token
# TRAVEL_UPDATE_CRON_SECRET=

# Optional logical key overrides for background run lock + status history
# TRAVEL_UPDATE_BACKGROUND_STATE_PATH=travel/background-state/default
# TRAVEL_UPDATE_BACKGROUND_LOCK_PATH=travel/background-lock/default

# Optional logical key override for ops action audit log (/api/travel-updates/ops/control)
# TRAVEL_UPDATE_OPS_AUDIT_PATH=travel/ops-audit/default

# Optional worker heartbeat thresholds (minutes) used by ops health policy
# TRAVEL_UPDATE_WORKER_DEADMAN_YELLOW_MINUTES=20
# TRAVEL_UPDATE_WORKER_DEADMAN_RED_MINUTES=60

# Optional expected scheduler cadence settings for deadman/schedule drift checks
# TRAVEL_UPDATE_SCHEDULE_INTERVAL_MINUTES=5
# TRAVEL_UPDATE_SCHEDULE_JITTER_MINUTES=2

# Optional alerting store key overrides
# TRAVEL_UPDATE_ALERT_STATE_PATH=travel/ops-alert-state/default
# TRAVEL_UPDATE_ALERT_AUDIT_PATH=travel/ops-alert-audit/default
# TRAVEL_ALERT_CONSOLE_ENABLED=true
# TRAVEL_ALERT_WEBHOOK_URL=
# TRAVEL_ALERT_EMAIL_ENDPOINT=
# TRAVEL_ALERT_SMS_ENDPOINT=
