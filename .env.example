# Copy to ".env.local" next to package.json, then restart `npm run dev`.
# Vercel: set the same names under Project → Settings → Environment Variables.

# Required for the map (https://www.maptiler.com/)
NEXT_PUBLIC_MAPTILER_KEY=

# Optional: foot routing via OpenRouteService (otherwise public OSRM demo)
# OPENROUTESERVICE_API_KEY=

# Optional: bump to bust stale browser chunks after deploys
# NEXT_PUBLIC_KEPI_BUILD=1

# Optional: transport update mode for travel assistant page.
# - auto: use configured server providers, fallback to mock when no keys
# - mock: force deterministic mock provider
# - off: disable provider checks
# NEXT_PUBLIC_TRAVEL_UPDATES_MODE=auto

# Optional server-side flight provider integration (kept private; do not use NEXT_PUBLIC_*)
# FLIGHT_STATUS_API_URL=
# FLIGHT_STATUS_API_KEY=

# Optional server-side rail provider integration (kept private; do not use NEXT_PUBLIC_*)
# RAIL_STATUS_API_URL=
# RAIL_STATUS_API_KEY=

# Optional server-side path for persistent idempotency/audit ledger
# TRAVEL_UPDATE_AUDIT_PATH=/tmp/kepi-travel-update-audit.json
