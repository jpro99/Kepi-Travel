# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (secrets); keep .env.example tracked for onboarding
.env*
!.env.example
!.env.test

# generated by postinstall (MapLibre CSP worker copy)
/public/maplibre-gl-csp-worker.js

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
